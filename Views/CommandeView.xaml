<UserControl x:Class="Borne.Views.CommandeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="752" d:DesignWidth="1100">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Zone catalogue -->
            <ColumnDefinition Width="*"/>
            <!-- Zone panier -->
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════
             COLONNE GAUCHE — Catalogue
        ══════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="{StaticResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <!-- En-tête -->
                <RowDefinition Height="70"/>
                <!-- Filtres catégories -->
                <RowDefinition Height="56"/>
                <!-- Grille des plats -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── En-tête ── -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="← Retour"
                                Style="{StaticResource BtnGhost}"
                                FontSize="13"
                                Padding="14,8"
                                Click="Retour_Click"/>
                        <TextBlock x:Name="txtTypeCommande"
                                   Text="COMMANDE"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                    </StackPanel>

                    <!-- Recherche rapide -->
                    <TextBox x:Name="txtRecherche"
                             Width="220"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             TextChanged="TxtRecherche_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Resources>
                                    <VisualBrush x:Key="hint" TileMode="None" Opacity="0.4"
                                                 Stretch="None" AlignmentX="Left">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="🔍 Rechercher un plat..."
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="14,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="{StaticResource hint}"/>
                                    </Trigger>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="Background" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>
            </Border>

            <!-- ── Filtres catégories ── -->
            <Border Grid.Row="1" Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="12,0">
                    <StackPanel x:Name="panelCategories"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"/>
                </ScrollViewer>
            </Border>

            <!-- ── Grille des plats ── -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16">
                <ItemsControl x:Name="itemsPlats">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Carte produit -->
                            <Border Width="220"
                                    Margin="8"
                                    Style="{StaticResource Card}"
                                    Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Pastille catégorie -->
                                    <Border Grid.Row="0"
                                            Background="{StaticResource BackgroundBrush}"
                                            CornerRadius="12,12,0,0"
                                            Padding="16,12">
                                        <StackPanel>
                                            <Border Background="{StaticResource AccentBrush}"
                                                    CornerRadius="4"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Categorie}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Infos -->
                                    <StackPanel Grid.Row="1" Margin="16,12">
                                        <TextBlock Text="{Binding Nom}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="48"/>
                                    </StackPanel>

                                    <!-- Prix + bouton ajouter -->
                                    <Border Grid.Row="2"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,1,0,0"
                                            Padding="16,12">
                                        <Grid>
                                            <TextBlock Text="{Binding Prix, StringFormat={}{0:C}}"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="+"
                                                    Style="{StaticResource BtnAccent}"
                                                    FontSize="20" FontWeight="Bold"
                                                    Width="38" Height="38"
                                                    Padding="0"
                                                    HorizontalAlignment="Right"
                                                    Tag="{Binding}"
                                                    Click="AjouterPlat_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="root"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="10"
                                                                Width="38" Height="38">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="root" Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="root" Property="Opacity" Value="0.7"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════════════════════
             COLONNE DROITE — Panier
        ══════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="{StaticResource PrimaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Titre panier ── -->
            <Border Grid.Row="0"
                    BorderBrush="#2E3D52"
                    BorderThickness="0,0,0,1">
                <StackPanel Margin="20,0" VerticalAlignment="Center">
                    <TextBlock Text="🛒  Votre commande"
                               FontSize="16" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="txtNbArticles"
                               Text="Panier vide"
                               FontSize="12"
                               Foreground="#90A4AE"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Liste des lignes du panier ── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="12,8">
                <ItemsControl x:Name="itemsPanier">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#253445"
                                    CornerRadius="8"
                                    Margin="0,4"
                                    Padding="12,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Nom + supprimer -->
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="{Binding Plat.Nom}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="180"/>
                                        <Button Content="✕"
                                                Style="{StaticResource BtnIcon}"
                                                Foreground="#90A4AE"
                                                HorizontalAlignment="Right"
                                                Tag="{Binding}"
                                                Click="SupprimerLigne_Click"/>
                                    </Grid>

                                    <!-- Quantité + sous-total -->
                                    <Grid Grid.Row="1" Margin="0,8,0,0">
                                        <!-- Contrôle quantité -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="−"
                                                    Style="{StaticResource BtnBase}"
                                                    Background="#1B2631"
                                                    Foreground="White"
                                                    FontSize="14"
                                                    Width="28" Height="28"
                                                    Padding="0"
                                                    Tag="{Binding}"
                                                    Click="DecrementerQte_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="r"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Width="28" Height="28">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="r" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <TextBlock Text="{Binding Quantite}"
                                                       Foreground="White"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Width="28"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <Button Content="+"
                                                    Style="{StaticResource BtnBase}"
                                                    Background="{StaticResource AccentBrush}"
                                                    Foreground="White"
                                                    FontSize="14"
                                                    Width="28" Height="28"
                                                    Padding="0"
                                                    Tag="{Binding}"
                                                    Click="IncrementerQte_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="r"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Width="28" Height="28">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="r" Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>

                                        <!-- Sous-total -->
                                        <TextBlock Text="{Binding SousTotal, StringFormat={}{0:C}}"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ── Total + validation ── -->
            <Border Grid.Row="2"
                    Background="#0F1923"
                    Padding="20,16">
                <StackPanel>
                    <!-- Séparateur -->
                    <Border Background="#2E3D52" Height="1" Margin="0,0,0,14"/>

                    <!-- Total -->
                    <Grid Margin="0,0,0,14">
                        <TextBlock Text="TOTAL"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#90A4AE"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtTotal"
                                   Text="0,00 €"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Bouton vider -->
                    <Button Content="🗑  Vider le panier"
                            Style="{StaticResource BtnBase}"
                            Background="#253445"
                            Foreground="#90A4AE"
                            FontSize="12"
                            Padding="0,8"
                            Margin="0,0,0,10"
                            Click="ViderPanier_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="root"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="root" Property="Background" Value="{StaticResource DangerBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Valider -->
                    <Button Content="✓  VALIDER LA COMMANDE"
                            Style="{StaticResource BtnSuccess}"
                            FontSize="15"
                            Padding="0,16"
                            Click="Valider_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="root"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="root" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="root" Property="Opacity" Value="0.72"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="root" Property="Opacity" Value="0.38"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
