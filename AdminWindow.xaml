<Window x:Class="Borne.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Administration — Borne"
        Height="680" Width="960"
        MinHeight="580" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Barre titre ══ -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="24,0">
                <TextBlock Text="⚙  Administration"
                           FontSize="16" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="txtAdminUser"
                           FontSize="13" Foreground="#90A4AE"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ Contenu avec onglets ══ -->
        <TabControl Grid.Row="1" Margin="16">

            <!-- ─────────────────────────────────────────
                 ONGLET 1 — Gestion des plats
            ───────────────────────────────────────── -->
            <TabItem Header="🍽  Gestion des plats">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <!-- Liste -->
                        <ColumnDefinition Width="*"/>
                        <!-- Formulaire -->
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Liste DataGrid ── -->
                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Toolbar -->
                            <Border Grid.Row="0"
                                    Background="{StaticResource BackgroundBrush}"
                                    CornerRadius="12,12,0,0"
                                    Padding="16,10">
                                <Grid>
                                    <TextBlock Text="Liste des plats"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="+ Nouveau plat"
                                                Style="{StaticResource BtnAccent}"
                                                FontSize="13" Padding="14,8"
                                                Click="BtnNouveauPlat_Click"/>
                                        <Button Content="🗑 Supprimer"
                                                Style="{StaticResource BtnDanger}"
                                                Margin="8,0,0,0"
                                                Click="BtnSupprimerPlat_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1"
                                      x:Name="gridPlats"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionChanged="GridPlats_SelectionChanged"
                                      Margin="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="50"/>
                                    <DataGridTextColumn Header="Nom"         Binding="{Binding Nom}"         Width="*"/>
                                    <DataGridTextColumn Header="Catégorie"   Binding="{Binding Categorie}"   Width="120"/>
                                    <DataGridTextColumn Header="Prix"        Binding="{Binding Prix, StringFormat={}{0:C}}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- ── Formulaire édition ── -->
                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock x:Name="txtFormTitre"
                                       Text="Nouveau plat"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,20"/>

                            <TextBlock Text="Nom" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtNom" Margin="0,0,0,14"/>

                            <TextBlock Text="Description" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtDescription" Height="72"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,14"/>

                            <TextBlock Text="Prix (€)" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtPrix" Margin="0,0,0,14"/>

                            <TextBlock Text="Catégorie" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cbCategorie"
                                      IsEditable="True"
                                      Margin="0,0,0,24">
                                <ComboBoxItem Content="Entrée"/>
                                <ComboBoxItem Content="Plat principal"/>
                                <ComboBoxItem Content="Accompagnement"/>
                                <ComboBoxItem Content="Dessert"/>
                                <ComboBoxItem Content="Boisson"/>
                            </ComboBox>

                            <Button x:Name="btnSauvegarder"
                                    Content="💾  Sauvegarder"
                                    Style="{StaticResource BtnSuccess}"
                                    Padding="0,12"
                                    Click="BtnSauvegarder_Click"/>

                            <!-- Message feedback -->
                            <TextBlock x:Name="txtFeedback"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─────────────────────────────────────────
                 ONGLET 2 — Personnalisation
            ───────────────────────────────────────── -->
            <TabItem Header="🎨  Personnalisation">
                <ScrollViewer Margin="0,12,0,0">
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left">

                        <!-- Carte identité -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Identité du restaurant"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,20"/>

                                <TextBlock Text="Nom du restaurant" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox x:Name="cfgNomRestaurant" Margin="0,0,0,16"/>

                                <TextBlock Text="Message d'accueil" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox x:Name="cfgWelcomeMessage" Margin="0,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Carte options commande -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Options de commande"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,20"/>

                                <CheckBox x:Name="chkSurPlace"
                                          Content="Activer l'option « Sur place »"
                                          FontSize="14"
                                          Foreground="{StaticResource TextBrush}"
                                          Margin="0,0,0,10"/>

                                <CheckBox x:Name="chkAEmporter"
                                          Content="Activer l'option « À emporter »"
                                          FontSize="14"
                                          Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Carte couleur accent -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Couleur d'accentuation"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Choisissez la couleur principale de l'interface"
                                           FontSize="13"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="0,0,0,16"/>

                                <!-- Swatches de couleur -->
                                <WrapPanel x:Name="panelSwatches"/>

                                <TextBlock Text="Hex personnalisé :" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="0,14,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="cfgAccentColor"
                                             Grid.Column="0"
                                             MaxLength="7"
                                             Margin="0,0,8,0"/>
                                    <Border Grid.Column="1"
                                            x:Name="previewColor"
                                            Width="40" Height="40"
                                            CornerRadius="8"
                                            Background="{StaticResource AccentBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Bouton sauvegarder config -->
                        <Button Content="💾  Sauvegarder la configuration"
                                Style="{StaticResource BtnAccent}"
                                FontSize="15" Padding="0,14"
                                Margin="0,0,0,16"
                                Click="BtnSauvegarderConfig_Click"/>

                        <TextBlock x:Name="txtConfigFeedback"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ─────────────────────────────────────────
                 ONGLET 3 — Base de données
            ───────────────────────────────────────── -->
            <TabItem Header="🗄  Base de données">
                <ScrollViewer Margin="0,12,0,0">
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Connexion MySQL / MariaDB"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,20"/>

                                <TextBlock Text="Serveur" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox x:Name="dbServer" Margin="0,0,0,14"/>

                                <TextBlock Text="Port" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox x:Name="dbPort" Margin="0,0,0,14"/>

                                <TextBlock Text="Base de données" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox x:Name="dbName" Margin="0,0,0,14"/>

                                <TextBlock Text="Utilisateur" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox x:Name="dbUser" Margin="0,0,0,14"/>

                                <TextBlock Text="Mot de passe" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="dbPassword" Margin="0,0,0,20"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Content="🔌 Tester la connexion"
                                            Style="{StaticResource BtnGhost}"
                                            Padding="0,12"
                                            Click="BtnTesterDb_Click"/>
                                    <Button Grid.Column="2"
                                            Content="💾 Sauvegarder"
                                            Style="{StaticResource BtnPrimary}"
                                            Padding="0,12"
                                            Click="BtnSauvegarderDb_Click"/>
                                </Grid>

                                <TextBlock x:Name="txtDbFeedback"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
