<Window x:Class="Borne.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Borne.Views"
        Title="Borne de Commande"
        Height="800" Width="1100"
        MinHeight="700" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="CanMinimize">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Barre du haut avec accès admin -->
            <RowDefinition Height="48"/>
            <!-- Contenu principal -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Barre supérieure ══ -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="16,0">
                <TextBlock x:Name="txtRestaurantName"
                           Text="Ma Borne"
                           FontSize="16" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="txtUsername"
                               FontSize="13" Foreground="#B0BEC5"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>

                    <!-- Bouton admin — visible uniquement pour les admins -->
                    <Button x:Name="btnAdmin"
                            Content="⚙ Administration"
                            Style="{StaticResource BtnAccent}"
                            FontSize="13"
                            Padding="14,6"
                            Visibility="Collapsed"
                            Click="BtnAdmin_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Vues principales ══ -->
        <Grid Grid.Row="1">
            <views:TypeCommandeView x:Name="typeCommandeView" />
            <views:CommandeView     x:Name="commandeView" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
